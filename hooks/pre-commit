#!/bin/sh
# ============================================================
# PRE-COMMIT HOOK — Petshop Service Management
# Chạy tự động trước mỗi git commit.
# Kiểm tra: TypeScript errors, ESLint, forbidden patterns
# ============================================================

echo "🔍 Pre-commit: Đang kiểm tra code..."

# --- Màu sắc terminal ---
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

PASS=true

# ============================================================
# 1. KIỂM TRA SECRETS / HARDCODE (QUAN TRỌNG NHẤT)
# ============================================================
echo "  🔒 Kiểm tra secrets và hardcode..."

# Các pattern cần chặn
FORBIDDEN_PATTERNS=(
  "password\s*=\s*['\"][^'\"]*['\"]"
  "secret\s*=\s*['\"][^'\"]*['\"]"
  "api_key\s*=\s*['\"][^'\"]*['\"]"
  "apikey\s*=\s*['\"][^'\"]*['\"]"
  "Bearer [A-Za-z0-9\-_]{20,}"
  "eyJ[A-Za-z0-9\-_]{20,}"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(ts|tsx|js|jsx|env)$")

for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
  if echo "$STAGED_FILES" | xargs grep -rliE "$pattern" 2>/dev/null | grep -v "node_modules" | grep -v ".env.example" | head -5 | grep -q .; then
    echo "  ${RED}❌ Phát hiện hardcode secret/token trong staged files!${NC}"
    echo "  ${RED}   Pattern: $pattern${NC}"
    echo "  ${YELLOW}   Hãy dùng process.env thay vì hardcode${NC}"
    PASS=false
  fi
done

# ============================================================
# 2. TYPESCRIPT TYPE CHECK (ChỈ check file staged)
# ============================================================
echo "  📘 Kiểm tra TypeScript..."

# Check frontend
if echo "$STAGED_FILES" | grep -q "apps/frontend"; then
  cd apps/frontend 2>/dev/null && npx tsc --noEmit --skipLibCheck 2>&1 | head -20
  TS_EXIT=$?
  cd - > /dev/null 2>&1
  if [ $TS_EXIT -ne 0 ]; then
    echo "  ${RED}❌ TypeScript errors trong frontend!${NC}"
    PASS=false
  fi
fi

# Check backend
if echo "$STAGED_FILES" | grep -q "apps/backend"; then
  cd apps/backend 2>/dev/null && npx tsc --noEmit --skipLibCheck 2>&1 | head -20
  TS_EXIT=$?
  cd - > /dev/null 2>&1
  if [ $TS_EXIT -ne 0 ]; then
    echo "  ${RED}❌ TypeScript errors trong backend!${NC}"
    PASS=false
  fi
fi

# ============================================================
# 3. KIỂM TRA FILE .ENV KHÔNG ĐƯỢC COMMIT
# ============================================================
echo "  🔐 Kiểm tra file .env..."

if git diff --cached --name-only | grep -E "^\.env$|^apps/.*\.env$" | grep -v ".env.example" | grep -q .; then
  echo "  ${RED}❌ Đang cố commit file .env thật!${NC}"
  echo "  ${YELLOW}   Hãy thêm vào .gitignore${NC}"
  PASS=false
fi

# ============================================================
# 4. KIỂM TRA FILE SIZE (tránh commit file lớn nhầm)
# ============================================================
echo "  📦 Kiểm tra kích thước file..."

MAX_SIZE_KB=500
git diff --cached --name-only | while read file; do
  if [ -f "$file" ]; then
    SIZE_KB=$(du -k "$file" | cut -f1)
    if [ "$SIZE_KB" -gt "$MAX_SIZE_KB" ]; then
      echo "  ${YELLOW}⚠️  File lớn: $file ($SIZE_KB KB > ${MAX_SIZE_KB}KB)${NC}"
      echo "  ${YELLOW}   Cân nhắc dùng .gitignore hoặc Git LFS${NC}"
    fi
  fi
done

# ============================================================
# KẾT QUẢ
# ============================================================
if [ "$PASS" = true ]; then
  echo "  ${GREEN}✅ Pre-commit passed! Đang commit...${NC}"
  exit 0
else
  echo ""
  echo "  ${RED}💥 Pre-commit FAILED. Commit bị từ chối.${NC}"
  echo "  ${YELLOW}   Sửa các lỗi trên rồi thử lại.${NC}"
  echo "  ${YELLOW}   Bỏ qua hook (không khuyến khích): git commit --no-verify${NC}"
  exit 1
fi
